{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@tam/core": ["../../packages/tam-core/src/index.ts"],
      "@tam/react": ["../../packages/tam-react/src/index.tsx"]
    }
  },
  "include": ["src", "../../packages/tam-core/src", "../../packages/tam-react/src"],
  // The app consumes the package SOURCES but not their tests — those own their toolchain (vitest) in
  // packages/tam-react and are type-checked there, not against the app's dependency set.
  "exclude": ["../../packages/**/*.test.ts", "../../packages/**/*.test.tsx"]
}
